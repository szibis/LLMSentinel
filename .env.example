# LLMSentinel Environment Configuration
# Copy to .env and fill in actual values for local development

# ============================================================================
# ANTHROPIC API CONFIGURATION
# ============================================================================

# Anthropic API Key (required for integration testing)
# Get this from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...your-api-key-here

# API Endpoint (optional, defaults to https://api.anthropic.com/v1)
# ANTHROPIC_API_BASE=https://api.anthropic.com/v1

# ============================================================================
# PHASE 1: INTEGRATION TESTING
# ============================================================================

# API Key for Phase 1 integration tests (must be set to run real API tests)
# Tests will be skipped if not provided
LLMSENTINEL_TEST_API_KEY=${ANTHROPIC_API_KEY}

# Sandbox/test API key (optional, for testing limits without production impact)
# LLMSENTINEL_TEST_SANDBOX_KEY=sk-ant-...sandbox-key

# ============================================================================
# SERVICE CONFIGURATION
# ============================================================================

# Service port (default: 9000)
LLMSENTINEL_PORT=9000

# Service host (default: localhost)
LLMSENTINEL_HOST=localhost

# Log level: debug, info, warn, error (default: info)
LLMSENTINEL_LOG_LEVEL=info

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# SQLite database path (default: ~/.claude/data/escalation/knowledge.db)
# LLMSENTINEL_DB_PATH=/path/to/database.db

# BoltDB path (default: ~/.claude/data/escalation/events.db)
# LLMSENTINEL_BOLTDB_PATH=/path/to/events.db

# ============================================================================
# CACHE CONFIGURATION
# ============================================================================

# Enable semantic caching (default: true)
LLMSENTINEL_CACHE_ENABLED=true

# Cache size limit in MB (default: 100)
LLMSENTINEL_CACHE_SIZE_MB=100

# ============================================================================
# PHASE 2: LOAD TESTING
# ============================================================================

# Load test target RPS (requests per second)
# LLMSENTINEL_LOAD_TEST_RPS=1000

# Load test duration (seconds)
# LLMSENTINEL_LOAD_TEST_DURATION=300

# ============================================================================
# PHASE 3: SECURITY TESTING
# ============================================================================

# Security audit verbose logging (default: false)
# LLMSENTINEL_SECURITY_AUDIT_VERBOSE=true

# ============================================================================
# PHASE 5: DATABASE OPERATIONS
# ============================================================================

# Backup directory (default: ~/.claude/data/escalation/backups)
# LLMSENTINEL_BACKUP_DIR=/path/to/backups

# Enable automatic backups (default: true)
# LLMSENTINEL_AUTO_BACKUP=true

# Backup interval in hours (default: 24)
# LLMSENTINEL_BACKUP_INTERVAL_HOURS=24
